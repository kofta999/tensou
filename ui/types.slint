// Shared data structures used across all UI components.

export struct Device {
    display_name: string,
    device_uuid: string,
    os_type: string,
    ip: string,
    port: int,
    initials: string,
}

export struct Transfer {
    id: int,
    is_sender: bool,
    job_name: string,
    total_bytes: string,
    bytes_transferred: string,
    progress: float,
    speed_eta: string,
}
