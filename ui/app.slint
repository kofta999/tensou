import { Button } from "std-widgets.slint";
import { Device, Transfer } from "types.slint";
import { TabButton } from "components.slint";
import { SendView } from "send-view.slint";
import { TransfersView } from "transfers-view.slint";
import { SettingsView } from "settings-view.slint";

export { Device, Transfer }

export component MainWindow inherits Window {
    title: "Tensou";
    width: 480px;
    height: 640px;
    background: #1a1b26; // Tokyo Night Void Base

    // Properties for communication with Rust
    in property <[Device]> devices: [];
    in property <[Transfer]> active_transfers: [];
    in property <string> download_dir: "/home/kofta/Downloads/Tensou";
    in property <int> listen_port: 6967;
    in property <string> direct_ip: "";

    // Consent Request popup properties
    in-out property <bool> has_consent_request: false;
    in-out property <int> consent_transfer_id: 0;
    in-out property <string> consent_peer_ip: "";
    in-out property <string> consent_job_name: "";

    // Active Screen properties
    in-out property <int> current_tab: 0; // 0 = Send, 1 = Transfers, 2 = Settings
    in-out property <bool> showing_device_actions: false;
    in-out property <Device> selected_device;

    // Callbacks to Rust
    callback change_tab(int);
    callback direct_send_file(string);
    callback direct_send_folder(string);
    callback device_send_file(Device);
    callback device_send_folder(Device);
    callback cancel_transfer(int);
    callback change_download_dir();
    callback consent_response(int, bool); // transfer_id, accepted
    callback direct_ip_changed(string);

    VerticalLayout {
        padding: 24px; // Zen spacing
        spacing: 20px;

        // Header
        HorizontalLayout {
            alignment: start;
            spacing: 12px;

            // Neon-Cyan "送" badge icon
            Rectangle {
                width: 36px;
                height: 36px;
                background: #7dcfff; // Neo-Cyan
                border-radius: 8px;
                Text {
                    text: "送";
                    font-size: 20px;
                    font-weight: 900;
                    color: #1a1b26; // Dark text on cyan badge
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            VerticalLayout {
                alignment: center;
                Text {
                    text: "Tensou";
                    font-size: 22px;
                    font-weight: 800;
                    color: #c0caf5; // Primary white/slate-blue
                }
            }
        }

        // Tab Bar
        HorizontalLayout {
            height: 44px;
            spacing: 12px;

            TabButton {
                text: "Send (Devices)";
                active: current_tab == 0;
                clicked => {
                    current_tab = 0;
                    change_tab(0);
                }
            }

            TabButton {
                text: active_transfers.length > 0 ? "Transfers (" + active_transfers.length + ")" : "Transfers";
                active: current_tab == 1;
                clicked => {
                    current_tab = 1;
                    change_tab(1);
                }
            }

            TabButton {
                text: "Settings";
                active: current_tab == 2;
                clicked => {
                    current_tab = 2;
                    change_tab(2);
                }
            }
        }

        // Content Area
        Rectangle {
            background: #24283b; // Lighter surface card
            border-radius: 12px; // Softer corners
            border-width: 0px;   // Remove harsh borders
            clip: true;

            // Tab 0: Send / Devices screen
            if current_tab == 0: SendView {
                devices: devices;
                direct_ip: direct_ip;
                showing_device_actions: showing_device_actions;
                selected_device: selected_device;

                direct_ip_changed(text) => {
                    direct_ip_changed(text);
                }
                direct_send_file(ip) => {
                    direct_send_file(ip);
                }
                direct_send_folder(ip) => {
                    direct_send_folder(ip);
                }
                device_send_file(dev) => {
                    device_send_file(dev);
                }
                device_send_folder(dev) => {
                    device_send_folder(dev);
                }
            }

            // Tab 1: Transfers monitor
            if current_tab == 1: TransfersView {
                active_transfers: active_transfers;
                cancel_transfer(id) => {
                    cancel_transfer(id);
                }
            }

            // Tab 2: Settings screen
            if current_tab == 2: SettingsView {
                download_dir: download_dir;
                listen_port: listen_port;
                change_download_dir() => {
                    change_download_dir();
                }
            }
        }
    }

    // Consent Modal popup overlay with Tokyo Night base backdrop
    if has_consent_request: Rectangle {
        background: rgba(26, 27, 38, 0.85); // Inky overlay
        width: 100%;
        height: 100%;

        Rectangle {
            width: 320px;
            height: 240px;
            background: #24283b; // Surface card
            border-radius: 12px;
            border-width: 2px;
            border-color: #f7768e; // Sakura Pink warning/consent border
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;

            VerticalLayout {
                padding: 24px;
                spacing: 16px;
                alignment: center;

                Text {
                    text: "Incoming Transfer Request";
                    font-size: 18px;
                    font-weight: 800;
                    color: #f7768e; // Sakura Pink
                    horizontal-alignment: center;
                }

                Text {
                    text: consent_peer_ip + " wants to send you:";
                    color: #565f89; // Secondary/dimmed
                    font-size: 13px;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }

                Text {
                    text: consent_job_name;
                    font-size: 16px;
                    font-weight: 700;
                    color: #ffffff; // White highlight
                    horizontal-alignment: center;
                    wrap: word-wrap;
                    overflow: elide;
                    max-height: 48px;
                }

                HorizontalLayout {
                    spacing: 16px;
                    alignment: center;

                    Button {
                        text: "Accept";
                        width: 110px;
                        clicked => {
                            consent_response(consent_transfer_id, true);
                            has_consent_request = false;
                        }
                    }

                    Button {
                        text: "Decline";
                        width: 110px;
                        clicked => {
                            consent_response(consent_transfer_id, false);
                            has_consent_request = false;
                        }
                    }
                }
            }
        }
    }
}
