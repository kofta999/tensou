import { LineEdit, ScrollView } from "std-widgets.slint";
import { Device } from "types.slint";
import { DeviceCard, ZenButton } from "components.slint";
import { Theme, AppData, Logic } from "globals.slint";

export component SendView inherits VerticalLayout {
    // Purely local UI state
    in-out property <bool> showing_device_actions: false;
    in-out property <Device> selected_device;

    padding: 24px;
    spacing: 20px;
    
    if !showing_device_actions : VerticalLayout {
        spacing: 18px;
        
        Text {
            text: "Local Network Devices";
            font-size: 16px;
            font-weight: 800;
            color: Theme.text-primary;
        }
        
        if AppData.devices.length == 0 : VerticalLayout {
            alignment: center;
            height: 120px;
            spacing: 12px;
            Text {
                text: "Scanning for receivers on the LAN...";
                color: Theme.text-secondary;
                horizontal-alignment: center;
                font-size: 14px;
            }
        }
        
        if AppData.devices.length > 0 : ScrollView {
            height: 150px;
            VerticalLayout {
                spacing: 10px;
                for dev in AppData.devices : DeviceCard {
                    dev: dev;
                    clicked => {
                        selected_device = dev;
                        showing_device_actions = true;
                    }
                }
            }
        }

        Rectangle {
            height: 1px;
            background: Theme.surface-hover;
        }

        Text {
            text: "Direct Connect";
            font-size: 16px;
            font-weight: 800;
            color: Theme.text-primary;
        }
        
        VerticalLayout {
            spacing: 10px;
            Text {
                text: "Target Device Address:";
                color: Theme.text-secondary;
                font-size: 13px;
                font-weight: 600;
            }
            
            ip_input := LineEdit {
                text: AppData.direct_ip;
                placeholder-text: "192.168.1.100:6967";
                edited(text) => {
                    AppData.direct_ip = text;
                    Logic.direct_ip_changed(text);
                }
            }
            
            HorizontalLayout {
                spacing: 12px;
                ZenButton {
                    text: "📄 Send File";
                    primary: true;
                    horizontal-stretch: 1;
                    clicked => {
                        Logic.direct_send_file(ip_input.text);
                    }
                }
                
                ZenButton {
                    text: "📁 Send Folder";
                    primary: false;
                    horizontal-stretch: 1;
                    clicked => {
                        Logic.direct_send_folder(ip_input.text);
                    }
                }
            }
        }
    }
    
    if showing_device_actions : VerticalLayout {
        spacing: 20px;
        
        ZenButton {
            text: "← Back to Devices";
            primary: false;
            clicked => {
                showing_device_actions = false;
            }
        }
        
        VerticalLayout {
            spacing: 10px;
            Text {
                text: "Send Destination";
                font-size: 14px;
                font-weight: 700;
                color: Theme.text-secondary;
            }
            
            Rectangle {
                background: Theme.background;
                border-radius: 12px;
                border-width: 1px;
                border-color: Theme.surface-hover;
                height: 84px;
                
                HorizontalLayout {
                    padding: 16px;
                    spacing: 18px;
                    alignment: start;
                    
                    Rectangle {
                        width: 52px;
                        height: 52px;
                        background: Theme.surface;
                        border-radius: 26px;
                        border-width: 2px;
                        border-color: Theme.secondary;
                        y: (parent.height - self.height) / 2;
                        
                        Text {
                            text: selected_device.initials;
                            color: Theme.secondary;
                            font-size: 20px;
                            font-weight: 800;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                    VerticalLayout {
                        alignment: center;
                        HorizontalLayout {
                            spacing: 8px;
                            alignment: start;
                            Text {
                                text: selected_device.display_name;
                                color: #ffffff;
                                font-weight: 800;
                                font-size: 18px;
                            }
                            Image {
                                source: selected_device.os_type == "linux" ? @image-url("icons/linux.svg") 
                                      : (selected_device.os_type == "windows" ? @image-url("icons/windows.svg") 
                                      : (selected_device.os_type == "macos" ? @image-url("icons/macos.svg") 
                                      : @image-url("icons/linux.svg")));
                                width: 18px;
                                height: 18px;
                                colorize: Theme.text-primary;
                                y: (parent.height - self.height) / 2;
                            }
                        }
                        Text {
                            text: selected_device.ip + ":" + selected_device.port;
                            color: Theme.text-secondary;
                            font-size: 13px;
                            font-weight: 500;
                        }
                    }
                }
            }
        }
        
        VerticalLayout {
            spacing: 12px;
            Text {
                text: "Select Content to Send";
                font-size: 14px;
                font-weight: 700;
                color: Theme.text-secondary;
            }
            
            HorizontalLayout {
                spacing: 12px;
                ZenButton {
                    text: "📄 Send File";
                    primary: true;
                    horizontal-stretch: 1;
                    clicked => {
                        Logic.device_send_file(selected_device);
                    }
                }
                ZenButton {
                    text: "📁 Send Folder";
                    primary: false;
                    horizontal-stretch: 1;
                    clicked => {
                        Logic.device_send_folder(selected_device);
                    }
                }
            }
        }
    }
}
