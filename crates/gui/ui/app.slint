import {
    Device,
    Transfer,
    ClipboardMessage,
    ConsentRequest,
    AppTab,
    CancelRequest,
    ToastType,
} from "types.slint";
import { TabButton, ZenButton } from "components.slint";
import { SendView } from "send-view.slint";
import { TransfersView } from "transfers-view.slint";
import { SettingsView } from "settings-view.slint";
import { Theme, AppData, Logic, ToastData } from "globals.slint";
import { Dialog } from "slintcn/components/dialog.slint";

export { Device, Transfer, ClipboardMessage, ConsentRequest, AppTab, CancelRequest, AppData, Logic, ToastData, ToastType }

export component MainWindow inherits Window {
    title: "Tensou";
    min-width: 400px;
    min-height: 500px;
    preferred-width: 480px;
    preferred-height: 640px;
    background: Theme.background;
    default-font-family: "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif";
    default-font-size: Theme.font-body;

    // Active Screen properties
    in-out property <AppTab> current_tab <=> AppData.current_tab;

    VerticalLayout {
        padding: 24px;
        spacing: 20px;

        // Header
        HorizontalLayout {
            alignment: start;
            spacing: 12px;

            Rectangle {
                width: 36px;
                height: 36px;
                background: Theme.secondary;
                border-radius: 8px;
                Text {
                    text: "送";
                    font-size: 20px;
                    font-weight: 900;
                    font-family: "PingFang SC, Microsoft YaHei, Noto Sans CJK SC, WenQuanYi Micro Hei, sans-serif";
                    color: #222333;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            VerticalLayout {
                alignment: center;
                Text {
                    text: "Tensou";
                    font-size: 22px;
                    font-weight: 800;
                    color: Theme.text-primary;
                }
            }
        }

        // Tab Bar
        HorizontalLayout {
            height: 44px;
            spacing: 10px;

            TabButton {
                text: "Send";
                active: current_tab == AppTab.send;
                clicked => {
                    current_tab = AppTab.send;
                    Logic.change_tab(AppTab.send);
                }
            }

            TabButton {
                text: AppData.active_transfers.length > 0 ? "Transfers (" + AppData.active_transfers.length + ")" : "Transfers";
                active: current_tab == AppTab.transfers;
                clicked => {
                    current_tab = AppTab.transfers;
                    Logic.change_tab(AppTab.transfers);
                }
            }

            TabButton {
                text: "Settings";
                active: current_tab == AppTab.settings;
                clicked => {
                    current_tab = AppTab.settings;
                    Logic.change_tab(AppTab.settings);
                }
            }
        }

        // Content Area
        Rectangle {
            background: Theme.surface;
            border-radius: 12px;
            border-width: 0px;
            clip: true;

            if current_tab == AppTab.send: SendView { }
            if current_tab == AppTab.transfers: TransfersView { }
            if current_tab == AppTab.settings: SettingsView { }
        }
    }

    // Consent Request Dialog
    Dialog {
        width: parent.width;
        height: parent.height;
        open <=> AppData.has_consent_request;
        title: "Incoming Transfer";
        description: "";
        show-close-button: false;
        dismissed => {
            Logic.consent_response(AppData.consent_request.transfer_id, false);
            AppData.has_consent_request = false;
        }

        // Nested Content
        VerticalLayout {
            spacing: 20px;

            // Sender Info Box
            Rectangle {
                background: Theme.background;
                border-radius: 8px;
                border-width: 1px;
                border-color: Theme.surface-hover;

                VerticalLayout {
                    padding: 12px;
                    spacing: 8px;

                    HorizontalLayout {
                        spacing: 8px;
                        alignment: start;

                        Image {
                            source: AppData.consent_request.device_os == "linux" ? @image-url("icons/linux.svg") : (AppData.consent_request.device_os == "windows" ? @image-url("icons/windows.svg") : (AppData.consent_request.device_os == "macos" ? @image-url("icons/macos.svg") : @image-url("icons/network.svg")));
                            width: 18px;
                            height: 18px;
                            colorize: Theme.secondary;
                            y: (parent.height - self.height) / 2;
                        }

                        Text {
                            text: AppData.consent_request.device_name != "" ? AppData.consent_request.device_name : "Unknown Device";
                            font-size: 14px;
                            font-weight: 700;
                            color: Theme.text-primary;
                            vertical-alignment: center;
                        }
                    }

                    Text {
                        text: "IP: " + AppData.consent_request.peer_ip;
                        font-size: 11px;
                        font-family: "monospace";
                        color: Theme.text-secondary;
                    }
                }
            }

            // File/Payload Section
            HorizontalLayout {
                spacing: 12px;
                alignment: start;

                Rectangle {
                    width: 36px;
                    height: 36px;
                    background: Theme.surface-hover;
                    border-radius: 6px;
                    y: (parent.height - self.height) / 2;

                    Image {
                        source: @image-url("icons/file.svg");
                        width: 18px;
                        height: 18px;
                        colorize: Theme.primary;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                    }
                }

                VerticalLayout {
                    alignment: center;
                    spacing: 2px;

                    Text {
                        text: "Wants to send you:";
                        font-size: 13px;
                        color: Theme.text-secondary;
                    }

                    Text {
                        text: AppData.consent_request.job_name;
                        font-size: 18px;
                        font-weight: 800;
                        color: Theme.text-primary;
                        wrap: word-wrap;
                        width: 250px;
                    }
                }
            }

            // Action Buttons Footer
            HorizontalLayout {
                spacing: 12px;
                alignment: stretch;

                ZenButton {
                    text: "Accept";
                    primary: true;
                    height: 36px;
                    horizontal-stretch: 1;
                    clicked => {
                        Logic.consent_response(AppData.consent_request.transfer_id, true);
                        AppData.has_consent_request = false;
                    }
                }

                ZenButton {
                    text: "Decline";
                    primary: false;
                    height: 36px;
                    horizontal-stretch: 1;
                    clicked => {
                        Logic.consent_response(AppData.consent_request.transfer_id, false);
                        AppData.has_consent_request = false;
                    }
                }
            }
        }
    }

    // Cancel Confirmation Dialog
    Dialog {
        width: parent.width;
        height: parent.height;
        open <=> AppData.has_cancel_confirmation;
        title: "Cancel Transfer?";
        description: "";
        show-close-button: false;
        dismissed => {
            AppData.has_cancel_confirmation = false;
        }

        // Nested Content
        VerticalLayout {
            spacing: 20px;

            // File Info Section
            HorizontalLayout {
                spacing: 12px;
                alignment: start;

                Rectangle {
                    width: 36px;
                    height: 36px;
                    background: Theme.surface-hover;
                    border-radius: 6px;
                    y: (parent.height - self.height) / 2;

                    Image {
                        source: @image-url("icons/file.svg");
                        width: 18px;
                        height: 18px;
                        colorize: Theme.primary;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                    }
                }

                VerticalLayout {
                    alignment: center;
                    spacing: 2px;

                    Text {
                        text: "Are you sure you want to cancel:";
                        font-size: 11px;
                        color: Theme.text-secondary;
                    }

                    Text {
                        text: AppData.cancel_request.job_name;
                        font-size: 15px;
                        font-weight: 700;
                        color: Theme.text-primary;
                        wrap: word-wrap;
                        width: 250px;
                    }
                }
            }

            // Action Buttons Footer
            HorizontalLayout {
                spacing: 12px;
                alignment: stretch;

                ZenButton {
                    text: "No, Keep It";
                    primary: false;
                    height: 36px;
                    horizontal-stretch: 1;
                    clicked => {
                        AppData.has_cancel_confirmation = false;
                    }
                }

                ZenButton {
                    text: "Yes, Cancel";
                    primary: true;
                    height: 36px;
                    horizontal-stretch: 1;
                    clicked => {
                        Logic.cancel_transfer(AppData.cancel_request.transfer_id);
                        AppData.has_cancel_confirmation = false;
                    }
                }
            }
        }
    }

    // Toast Notification Overlay
    Rectangle {
        background: ToastData.toast_type == ToastType.success ? Theme.success : (ToastData.toast_type == ToastType.error ? Theme.error : Theme.info);
        border-radius: 8px;
        height: layout.preferred-height;
        width: 320px;
        x: (parent.width - self.width) / 2;
        y: ToastData.show ? 20px : -100px; // Slide down animation
        opacity: ToastData.show ? 1.0 : 0.0;

        drop-shadow-color: rgba(0, 0, 0, 0.4);
        drop-shadow-blur: 16px;

        animate y {
            duration: 300ms;
            easing: ease-out-back;
        }
        animate opacity { duration: 250ms; }

        layout := HorizontalLayout {
            padding-left: 16px;
            padding-right: 16px;
            padding-top: 12px;
            padding-bottom: 12px;
            spacing: 10px;
            alignment: start;

            Image {
                source: ToastData.toast_type == ToastType.success ? @image-url("icons/check.svg") : @image-url("icons/info.svg");
                width: 18px;
                height: 18px;
                colorize: Theme.text-dark;
                y: (parent.height - self.height) / 2;
            }

            Text {
                text: ToastData.message;
                color: Theme.text-dark;
                font-size: 13px;
                font-weight: 800;
                vertical-alignment: center;
                wrap: word-wrap;
                horizontal-stretch: 1;
            }
        }

        // Hide on click
        TouchArea {
            clicked => {
                ToastData.show = false;
            }
        }
    }
}
