import { ScrollView } from "std-widgets.slint";
import { Transfer, AppTab } from "types.slint";
import { ProgressBar, ZenButton, ClipboardEntryCard } from "components.slint";
import { Theme, AppData, Logic } from "globals.slint";

export component TransfersView inherits VerticalLayout {
    padding: 24px;
    spacing: 16px;

    ScrollView {
        vertical-stretch: 1;
        VerticalLayout {
            alignment: start;
            spacing: 24px;

            // Active Transfers Section
            VerticalLayout {
                spacing: 12px;

                HorizontalLayout {
                    spacing: 8px;
                    alignment: start;

                    Text {
                        text: "Active Transfers";
                        font-size: 15px;
                        font-weight: 800;
                        color: Theme.text-primary;
                        vertical-alignment: center;
                    }

                    Rectangle {
                        background: Theme.surface-hover;
                        border-radius: 9px;
                        height: 18px;
                        width: active_badge_text.preferred-width + 12px;
                        y: (parent.height - self.height) / 2;

                        active_badge_text := Text {
                            text: AppData.active_transfers.length;
                            color: Theme.text-secondary;
                            font-size: 11px;
                            font-weight: 800;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }

                if AppData.active_transfers.length == 0: VerticalLayout {
                    spacing: 16px;
                    padding-top: 24px;
                    padding-bottom: 24px;

                    // Styled minimalist transfer icon placeholder
                    Rectangle {
                        width: 72px;
                        height: 72px;
                        background: Theme.surface-hover;
                        border-radius: 36px;
                        border-width: 1px;
                        border-color: Theme.secondary;
                        x: (parent.width - self.width) / 2;

                        Image {
                            source: @image-url("icons/file.svg");
                            width: 32px;
                            height: 32px;
                            colorize: Theme.secondary;
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                        }
                    }

                    VerticalLayout {
                        spacing: 6px;
                        Text {
                            text: "No Active Transfers";
                            color: Theme.text-primary;
                            horizontal-alignment: center;
                            font-size: 16px;
                            font-weight: 800;
                        }

                        Text {
                            text: "Your active file transfers will appear here.";
                            color: Theme.text-secondary;
                            horizontal-alignment: center;
                            font-size: 12px;
                        }
                    }

                    ZenButton {
                        text: "Send a File";
                        primary: false;
                        width: 140px;
                        height: 36px;
                        x: (parent.width - self.width) / 2;
                        clicked => {
                            AppData.current_tab = AppTab.send; // Go to Send tab
                        }
                    }
                }

                if AppData.active_transfers.length > 0: VerticalLayout {
                    spacing: 12px;
                    for transfer in AppData.active_transfers: Rectangle {
                        background: Theme.background;
                        border-radius: 12px;
                        border-width: 1px;
                        border-color: Theme.surface-hover;

                        VerticalLayout {
                            padding: 16px;
                            spacing: 10px;

                            HorizontalLayout {
                                alignment: space-between;
                                Text {
                                    text: (transfer.is_sender ? "Sending: " : "Receiving: ") + transfer.job_name;
                                    color: Theme.text-primary;
                                    font-weight: 800;
                                    font-size: 14px;
                                    width: 190px;
                                    overflow: elide;
                                }

                                ZenButton {
                                    text: "Cancel";
                                    width: 72px;
                                    height: 32px;
                                    clicked => {
                                        AppData.cancel_request = { transfer_id: transfer.id, job_name: transfer.job_name };
                                        AppData.has_cancel_confirmation = true;
                                    }
                                }
                            }

                            // Speed / ETA promoted to a bold, prominent line
                            HorizontalLayout {
                                alignment: space-between;
                                Text {
                                    text: transfer.speed_eta;
                                    color: Theme.secondary;
                                    font-size: 12px;
                                    font-weight: 600;
                                }

                                Text {
                                    text: transfer.bytes_transferred;
                                    color: Theme.text-secondary;
                                    font-size: 12px;
                                    font-weight: 600;
                                    vertical-alignment: center;
                                }
                            }

                            // Sized progress bar
                            HorizontalLayout {
                                padding-left: 20px;
                                padding-right: 20px;
                                ProgressBar {
                                    progress: transfer.progress;
                                    is_sender: transfer.is_sender;
                                    bar_height: 24px;
                                }
                            }
                        }
                    }
                }
            }

            // Completed Transfers Section
            VerticalLayout {
                spacing: 12px;

                HorizontalLayout {
                    spacing: 8px;
                    alignment: start;

                    Text {
                        text: "Session History";
                        font-size: 15px;
                        font-weight: 800;
                        color: Theme.text-primary;
                        vertical-alignment: center;
                    }

                    Rectangle {
                        background: Theme.surface-hover;
                        border-radius: 9px;
                        height: 18px;
                        width: history_badge_text.preferred-width + 12px;
                        y: (parent.height - self.height) / 2;

                        history_badge_text := Text {
                            text: AppData.completed_transfers.length;
                            color: Theme.text-secondary;
                            font-size: 11px;
                            font-weight: 800;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }

                if AppData.completed_transfers.length == 0: Text {
                    text: "No transfers in session history yet.";
                    color: Theme.text-secondary;
                    font-size: 13px;
                }

                if AppData.completed_transfers.length > 0: VerticalLayout {
                    spacing: 12px;
                    for transfer in AppData.completed_transfers: Rectangle {
                        background: Theme.background;
                        border-radius: 12px;
                        border-width: 1px;
                        border-color: Theme.surface-hover;

                        VerticalLayout {
                            padding: 16px;
                            spacing: 12px;

                            HorizontalLayout {
                                alignment: space-between;
                                Text {
                                    text: (transfer.is_sender ? "Sent: " : "Received: ") + transfer.job_name;
                                    color: transfer.is_sender ? Theme.primary : Theme.success;
                                    font-weight: 800;
                                    font-size: 14px;
                                    width: 200px;
                                    overflow: elide;
                                }

                                ZenButton {
                                    text: "Open Folder";
                                    width: 110px;
                                    height: 32px;
                                    clicked => {
                                        Logic.open_transfer_folder(transfer.id);
                                    }
                                }
                            }

                            HorizontalLayout {
                                alignment: space-between;
                                Text {
                                    text: "Size: " + transfer.total_bytes;
                                    color: Theme.text-secondary;
                                    font-size: 12px;
                                    font-weight: 600;
                                }

                                Text {
                                    text: transfer.speed_eta;
                                    color: transfer.speed_eta == "Completed" ? Theme.success : (transfer.speed_eta == "Cancelled" ? Theme.secondary : Theme.error);
                                    font-size: 12px;
                                    font-weight: 600;
                                }
                            }
                            HorizontalLayout {
                                alignment: space-between;
                                Text {
                                    text: (transfer.is_sender ? "To: " : "From: ") + transfer.peer_name;
                                    color: Theme.text-secondary;
                                    font-size: 12px;
                                    font-weight: 600;
                                }

                                Text {
                                    text: transfer.timestamp;
                                    color: Theme.text-secondary;
                                    font-size: 12px;
                                    font-weight: 600;
                                }
                            }
                        }
                    }
                }
            }

            // Received Text Section (Received This Session)
            VerticalLayout {
                spacing: 12px;

                HorizontalLayout {
                    alignment: space-between;

                    HorizontalLayout {
                        spacing: 8px;
                        alignment: start;

                        Text {
                            text: "Received Text / Clipboard";
                            font-size: 15px;
                            font-weight: 800;
                            color: Theme.text-primary;
                            vertical-alignment: center;
                        }

                        Rectangle {
                            background: Theme.surface-hover;
                            border-radius: 9px;
                            height: 18px;
                            width: clipboard_badge_text.preferred-width + 12px;
                            y: (parent.height - self.height) / 2;

                            clipboard_badge_text := Text {
                                text: AppData.clipboard_history.length;
                                color: Theme.text-secondary;
                                font-size: 11px;
                                font-weight: 800;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }

                    if AppData.clipboard_history.length > 0: ZenButton {
                        text: "Clear";
                        width: 70px;
                        height: 28px;
                        clicked => {
                            Logic.clear_clipboard_history();
                        }
                    }
                }

                if AppData.clipboard_history.length == 0: Text {
                    text: "No text or clipboard content received yet.";
                    color: Theme.text-secondary;
                    font-size: 13px;
                }

                if AppData.clipboard_history.length > 0: VerticalLayout {
                    spacing: 8px;
                    for msg in AppData.clipboard_history: ClipboardEntryCard {
                        msg: msg;
                        copy_clicked => {
                            Logic.copy_to_clipboard(msg.content);
                        }
                    }
                }
            }
        }
    }
}
