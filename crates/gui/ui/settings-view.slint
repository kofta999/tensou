import { LineEdit, ScrollView } from "std-widgets.slint";
import { ZenButton, ZenToggle } from "components.slint";
import { Theme, AppData, Logic } from "globals.slint";

export component SettingsView inherits ScrollView {
    Rectangle {
        height: layout.preferred-height;
        background: transparent;

        dummy_focus := FocusScope { }

        // Background click-away handler to clear focus from LineEdit
        TouchArea {
            width: 100%;
            height: 100%;
            clicked => {
                dummy_focus.focus();
            }
        }

        layout := VerticalLayout {
            padding: 24px;
            spacing: 18px;

            Text {
                text: "Application Settings";
                font-size: 18px;
                font-weight: 800;
                color: Theme.text-primary;
            }

            // Section 1: Device Identity
            VerticalLayout {
                spacing: 10px;

                Text {
                    text: "Device Identity";
                    color: Theme.text-secondary;
                    font-size: 13px;
                    font-weight: 700;
                }

                Rectangle {
                    background: Theme.background;
                    border-radius: 12px;
                    border-width: 1px;
                    border-color: Theme.surface-hover;

                    VerticalLayout {
                        padding: 16px;
                        spacing: 12px;

                        HorizontalLayout {
                            spacing: 12px;
                            alignment: start;

                            Image {
                                source: AppData.os_type == "linux" ? @image-url("icons/linux.svg") : (AppData.os_type == "windows" ? @image-url("icons/windows.svg") : (AppData.os_type == "macos" ? @image-url("icons/macos.svg") : @image-url("icons/linux.svg")));
                                width: 24px;
                                height: 24px;
                                colorize: Theme.secondary;
                                y: (parent.height - self.height) / 2;
                            }

                            VerticalLayout {
                                alignment: center;
                                Text {
                                    text: "Display Name (edit to rename)";
                                    color: Theme.text-secondary;
                                    font-size: 11px;
                                    font-weight: 600;
                                }

                                name_input := LineEdit {
                                    text: AppData.display_name;
                                    placeholder-text: "Device Name";
                                    edited(text) => {
                                        AppData.display_name = text;
                                        Logic.update_display_name(text);
                                    }
                                }
                            }
                        }

                        // UUID badge
                        VerticalLayout {
                            spacing: 4px;
                            Text {
                                text: "Device UUID";
                                color: Theme.text-secondary;
                                font-size: 11px;
                                font-weight: 600;
                            }

                            Text {
                                text: AppData.device_uuid;
                                color: Theme.text-secondary.transparentize(0.3);
                                font-size: 11px;
                                font-family: "monospace";
                            }
                        }
                    }
                }
            }

            // Section 2: Save Location
            VerticalLayout {
                spacing: 10px;
                Text {
                    text: "Download Location";
                    color: Theme.text-secondary;
                    font-size: 13px;
                    font-weight: 700;
                }

                Rectangle {
                    background: Theme.background;
                    border-radius: 12px;
                    border-width: 1px;
                    border-color: Theme.surface-hover;

                    VerticalLayout {
                        padding: 14px;
                        Text {
                            text: AppData.download_dir;
                            color: #ffffff;
                            font-weight: 700;
                            wrap: word-wrap;
                        }
                    }
                }

                ZenButton {
                    text: "📁 Change Location";
                    primary: false;
                    clicked => {
                        Logic.change_download_dir();
                    }
                }
            }

            // Section 3: Preferences & Port
            VerticalLayout {
                spacing: 12px;

                Rectangle {
                    height: 1px;
                    background: Theme.surface-hover;
                }

                HorizontalLayout {
                    alignment: space-between;
                    VerticalLayout {
                        alignment: center;
                        Text {
                            text: "Overwrite Existing Files";
                            color: Theme.text-primary;
                            font-size: 14px;
                            font-weight: 600;
                        }

                        Text {
                            text: "Replace local files if they have the same name";
                            color: Theme.text-secondary;
                            font-size: 11px;
                        }
                    }

                    ZenToggle {
                        checked: AppData.overwrite_dest;
                        toggled(val) => {
                            AppData.overwrite_dest = val;
                            Logic.toggle_overwrite_dest(val);
                        }
                        y: (parent.height - self.height) / 2;
                    }
                }

                HorizontalLayout {
                    VerticalLayout {
                        alignment: center;
                        Text {
                            text: "Auto Accept Requests";
                            color: Theme.text-primary;
                            font-size: 14px;
                            font-weight: 600;
                        }

                        Text {
                            text: "Auto accept all incoming requests (use with caution)";
                            color: Theme.text-secondary;
                            font-size: 11px;
                        }
                    }

                    ZenToggle {
                        checked: AppData.auto_accept;
                        toggled(val) => {
                            AppData.auto_accept = val;
                            Logic.toggle_auto_accept(val);
                        }
                        y: (parent.height - self.height) / 2;
                    }
                }

                Rectangle {
                    height: 1px;
                    background: Theme.surface-hover;
                }

                HorizontalLayout {
                    alignment: space-between;
                    Text {
                        text: "Listening Network Port";
                        color: Theme.text-secondary;
                        font-size: 14px;
                        font-weight: 600;
                    }

                    Text {
                        text: AppData.listen_port;
                        color: Theme.secondary;
                        font-weight: 800;
                        font-size: 14px;
                    }
                }
            }
        }
    }
}
