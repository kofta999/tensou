// slintcn default theme mapped to Tensou's global Theme
import { Theme as AppTheme } from "../../globals.slint";
import { Palette } from "palette.slint";

export enum ThemeMode { dark, light }

export global Theme {
    in-out property <ThemeMode> mode: AppTheme.is_dark ? ThemeMode.dark : ThemeMode.light;
}

export global Tokens {
    // surfaces mapped to Tensou theme
    out property <color> color-background: AppTheme.background;
    out property <color> color-foreground: AppTheme.text-primary;
    out property <color> color-card: AppTheme.surface;
    out property <color> color-card-foreground: AppTheme.text-primary;

    // intent
    out property <color> color-primary: AppTheme.primary;
    out property <color> color-primary-foreground: AppTheme.text-dark;
    out property <color> color-secondary: AppTheme.secondary;
    out property <color> color-muted: AppTheme.surface-hover;
    out property <color> color-muted-foreground: AppTheme.text-secondary;
    out property <color> color-destructive: AppTheme.error;
    out property <color> color-affirm: AppTheme.success;
    out property <color> color-accent: AppTheme.surface-hover;
    out property <color> color-subtle-foreground: AppTheme.text-secondary.transparentize(0.2);
    out property <color> color-scrim-0: Palette.alpha-b-30;
    out property <color> color-scrim-1: Palette.alpha-b-45;

    // focus / interaction
    out property <color> color-ring: AppTheme.secondary;
    out property <color> color-ring-muted: AppTheme.secondary.transparentize(0.5);
    out property <length> focus-ring-width:  2px;
    out property <length> focus-ring-offset: 1px;

    // glass / scrim / hairline
    out property <color> color-surface-1: AppTheme.surface;
    out property <color> color-surface-2: AppTheme.surface-hover;
    out property <color> color-surface-3: AppTheme.background;
    out property <color> color-scrim-2: Palette.alpha-b-60;
    out property <color> color-border-hairline: AppTheme.surface-hover;
    out property <color> color-border-hairline-strong: AppTheme.text-secondary.transparentize(0.5);

    // radius
    out property <length> radius-sm: 6px;
    out property <length> radius-md: 8px;
    out property <length> radius-lg: 12px;
    out property <length> radius-xl: 16px;

    // motion
    out property <duration> motion-fast: 150ms;
    out property <duration> motion-base: 200ms;
    out property <easing>   motion-easing-standard:    cubic-bezier(0.4, 0.0, 0.2, 1.0);
    out property <easing>   motion-easing-emphasized:  cubic-bezier(0.05, 0.7, 0.1, 1.0);

    // elevation shadows
    out property <length> shadow-e2-blur:     8px;
    out property <length> shadow-e2-offset-y: 2px;
    out property <color>  shadow-e2-color:    Palette.alpha-b-32;
    out property <length> shadow-e3-blur:     24px;
    out property <length> shadow-e3-offset-y: 8px;
    out property <color>  shadow-e3-color:    Palette.alpha-b-38;

    // glow effects
    out property <length> shadow-glow-md-blur:  16px;
    out property <color>  shadow-glow-md-color: AppTheme.secondary.transparentize(0.7);
    out property <length> shadow-glow-lg-blur:  24px;
    out property <color>  shadow-glow-lg-color: AppTheme.secondary.transparentize(0.6);

    // typography (bound to Tensou typography settings)
    out property <int>    typography-weight-medium:     500;
    out property <int>    typography-weight-semibold:   600;
    out property <length> typography-body-sm-size:      AppTheme.font-caption;
    out property <length> typography-body-size:         AppTheme.font-body;
    out property <length> typography-label-size:        AppTheme.font-small;
    out property <length> typography-title-size:        AppTheme.font-header;
    out property <length> typography-h2-size:           AppTheme.font-header;
    out property <length> typography-h1-size:           AppTheme.font-title;

    // spacing
    out property <length> spacing-xs:  AppTheme.spacing-xs;
    out property <length> spacing-sm:  AppTheme.spacing-sm;
    out property <length> spacing-md:  AppTheme.spacing-md;
    out property <length> spacing-lg:  AppTheme.spacing-lg;
    out property <length> spacing-xl:  AppTheme.spacing-xl;
    out property <length> spacing-2xl: 32px;

    // control density
    out property <length> density-button-xs:      28px;
    out property <length> density-button-sm:      32px;
    out property <length> density-button-default: 38px;
    out property <length> density-button-lg:      44px;
    out property <length> density-input:          38px;
    out property <length> density-control:        38px;
}
