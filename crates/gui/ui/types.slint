// Shared data structures used across all UI components.

export struct Device {
    display_name: string,
    device_uuid: string,
    os_type: string,
    ip: string,
    port: int,
    initials: string,
    avatar_color: color,
}

export struct Transfer {
    id: int,
    is_sender: bool,
    job_name: string,
    total_bytes: string,
    bytes_transferred: string,
    progress: float,
    speed_eta: string,
    timestamp: string,
    peer_name: string,
}

export struct ClipboardMessage {
    id: int,
    sender_name: string,
    sender_ip: string,
    content: string,
}

export struct ConsentRequest {
    transfer_id: int,
    peer_ip: string,
    device_name: string,
    device_os: string,
    job_name: string,
}

export enum AppTab {
    send,
    transfers,
    settings,
}

export struct CancelRequest {
    transfer_id: int,
    job_name: string,
}

export enum ToastType {
    success,
    error,
    info
}
